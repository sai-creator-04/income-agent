# ─────────────────────────────────────────────────────────────
# INCOME AGENT — Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── ANTHROPIC (Claude AI brain) ──────────────────────────────
# Get yours: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── TELEGRAM (your notification inbox) ───────────────────────
# Step 1: Message @BotFather on Telegram → /newbot → follow prompts
# Step 2: Copy the bot token here
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIjKlmNoPqRsTuVwXyZ

# Step 3: Message @userinfobot on Telegram → it tells you your chat ID
TELEGRAM_CHAT_ID=987654321

# ── GMAIL (sends auto-replies to buyers) ─────────────────────
# Use your real Gmail address
GMAIL_ADDRESS=you@gmail.com

# App Password (NOT your Gmail password):
# Google Account → Security → 2-Step Verification ON → App Passwords
# Select "Mail" + "Other (custom)" → generate → paste here
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# ── BUFFER (schedules Twitter posts) ─────────────────────────
# buffer.com → connect Twitter → buffer.com/developers/apps → create app
# Copy the Access Token here
BUFFER_ACCESS_TOKEN=your-buffer-access-token

# ── GUMROAD (your storefront) ────────────────────────────────
# Your Gumroad product short URL (find in product settings)
GUMROAD_LINK=https://gum.co/your-product

# Upsell product link (the second product buyers get offered)
GUMROAD_UPSELL_LINK=https://gum.co/your-upsell

# Webhook secret — set this in Gumroad dashboard under Webhooks
# Can be any random string, e.g.: openssl rand -hex 20
GUMROAD_WEBHOOK_SECRET=your-random-secret-here

# ── APIFY (finds Twitter targets for DM agent) ────────────────
# apify.com → free account → apify.com/account/integrations → copy token
# Free tier: $5 credit/month — enough for daily searches
APIFY_API_TOKEN=apify_api_your-token-here

# ── SERVER ───────────────────────────────────────────────────
PORT=8080
